# Copy to .env.local for development. NEVER commit a populated .env file.
# In production, inject these via your secrets manager (Key Vault / AWS Secrets Manager),
# not via plain environment files on disk.

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/posture_platform?schema=public"

# --- Portal auth (NextAuth) ---
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# Entra ID (Azure AD) app registration used for PORTAL LOGIN (myCIO staff/customer SSO).
# This is separate from each customer tenant's monitoring app registration.
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Defense-in-depth check for Conditional Access MFA, backing up (never replacing)
# the Conditional Access policy that is the authoritative control — see
# src/lib/auth/README.md "MFA / step-up authentication" for the full explanation,
# including the one-time Entra app registration change (adding the "amr" optional
# claim) required for this to work at all.
#
# Unset/false (default, RECOMMENDED to start): warn-only. If Entra's "amr" claim
# is missing or doesn't indicate MFA was completed, sign-in is still ALLOWED, but
# a loud warning is logged identifying the user. Safe default because enabling
# fail-closed before the "amr" optional claim is configured in Entra would lock
# out every user (the claim would never be present).
#
# Set to "true" (or "1") to fail-closed: sign-in is DENIED when the "amr" claim
# is missing or doesn't indicate MFA. Only enable this after confirming, via the
# warn-only logs, that the "amr" claim is actually flowing through correctly for
# real sign-ins.
ENFORCE_MFA_CLAIM=""

# --- Credential envelope encryption ---
# Production KMS backend: Azure Key Vault. Wraps/unwraps the per-credential AES-256
# data-encryption key (DEK) via Key Vault's RSA-OAEP-256 key-wrap operation — Key
# Vault never sees the credential plaintext itself, only the small 32-byte DEK.
# See src/lib/crypto/README.md for the one-time Key Vault setup (key type,
# permissions, access policy) an operator must do before this works.
#
# Base URL of the Key Vault instance, e.g. "https://<vault-name>.vault.azure.net/".
# Required together with CREDENTIAL_KMS_KEY_ID below (both or neither).
AZURE_KEY_VAULT_URL=""
# Name (not full resource ID/URL) of the RSA key *within* that vault used to
# wrap/unwrap credential data keys, e.g. "posture-platform-credential-wrap".
# NOTE: this env var predates the Key Vault integration; its semantic is now
# finalized as "Key Vault key name" (see README.md). In production this must be
# set together with AZURE_KEY_VAULT_URL above.
CREDENTIAL_KMS_KEY_ID=""
# Optional: pin a specific Key Vault key version instead of always using the
# key's current/latest version. Usually leave unset — the actual version used
# for each wrap operation is recorded per-credential regardless, so rotating the
# key's current version in Key Vault does not break decrypting older records.
CREDENTIAL_KMS_KEY_VERSION=""
# Local-dev-only fallback data key (32 bytes, base64). Never use in production.
CREDENTIAL_DEV_DATA_KEY=""
#
# Azure Key Vault authentication uses DefaultAzureCredential (@azure/identity),
# which transparently supports Managed Identity when running on Azure
# infrastructure. When running off-Azure (e.g. on Railway), authenticate via a
# service principal by setting the standard Azure SDK env vars below (distinct
# from AZURE_AD_CLIENT_ID/SECRET/TENANT_ID above, which are for portal login) —
# DefaultAzureCredential reads these automatically, no code change needed:
# AZURE_CLIENT_ID=""
# AZURE_CLIENT_SECRET=""
# AZURE_TENANT_ID=""

# --- Tenant onboarding: admin-consent link generation ---
# Client (application) ID of THIS PLATFORM's own multi-tenant Entra ID app
# registration — the one customer Global Admins grant admin consent to during
# tenant onboarding (see src/app/(onboarding)). This is NOT the portal login
# app registration (AZURE_AD_CLIENT_ID above) and NOT a per-tenant credential;
# it is a single, platform-wide, multi-tenant app registration id used only to
# build the `https://login.microsoftonline.com/{tenant-id}/adminconsent?client_id={this}`
# URL shown to analysts during onboarding.
PLATFORM_MULTI_TENANT_APP_CLIENT_ID=""

# --- Background collection worker ---
COLLECTION_INTERVAL_CRON="0 */6 * * *"
